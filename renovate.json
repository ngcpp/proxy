{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": [
    "github-actions",
    "pre-commit",
    "pip_requirements",
    "bazel-module",
    "bazelisk"
  ],
  "pre-commit": {
    "enabled": true
  },
  "separateMajorMinor": false,
  "prHourlyLimit": 0,
  "branchPrefix": "auto/bump-renovate-",
  "packageRules": [
    {
      "description": "One weekly PR on auto/bump-renovate-deps.",
      "matchManagers": [
        "github-actions",
        "pre-commit",
        "pip_requirements",
        "bazel-module",
        "bazelisk"
      ],
      "groupName": "dependencies",
      "groupSlug": "deps"
    }
  ]
}
